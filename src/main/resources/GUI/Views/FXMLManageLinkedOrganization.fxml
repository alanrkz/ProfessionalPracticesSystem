<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="565.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Controllers.FXMLManageLinkedOrganizationController">
   <children>
      <Label fx:id="labelTitleManageLinkedOrganization" layoutX="128.0" layoutY="39.0" text="Gestionar Organizacion Vinculada">
         <font>
            <Font name="Times New Roman Bold" size="24.0" />
         </font>
      </Label>
      <Button fx:id="buttonInsertLinkedOrganization" layoutX="193.0" layoutY="135.0" mnemonicParsing="false" onAction="#buttonInsertLinkedOrganization" prefHeight="26.0" prefWidth="222.0" text="Registrar Organizacion Vinculada" />
      <Label fx:id="labelSelectLinkedOrganization" layoutX="167.0" layoutY="273.0" text="Selecciona la Organizacion Vinculada:">
         <font>
            <Font name="Times New Roman" size="18.0" />
         </font>
      </Label>
      <ComboBox fx:id="comboBoxLinkedOrganizations" layoutX="232.0" layoutY="334.0" prefWidth="150.0" />
      <Button fx:id="buttonUpdate" layoutX="106.0" layoutY="412.0" mnemonicParsing="false" onAction="#buttonUpdate" text="Actualizar" />
      <Button fx:id="buttonDeactive" layoutX="443.0" layoutY="412.0" mnemonicParsing="false" onAction="#buttonDeactive" text="Inactivar" />
      <Button fx:id="buttonBack" layoutX="276.0" layoutY="504.0" mnemonicParsing="false" onAction="#buttonBack" text="Regresar" />
   </children>
</AnchorPane>
