<AnchorPane id="AnchorPane" prefHeight="565.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Controllers.FXMLUploadDocumentController">
   <children>
      <Label layoutX="210.0" layoutY="37.0" text="Subir Documento">
         <font>
            <Font name="Times New Roman Bold" size="24.0" />
         </font>
      </Label>
      <Label layoutX="211.0" layoutY="107.0" text="Seleccione el tipo de documento:" />
