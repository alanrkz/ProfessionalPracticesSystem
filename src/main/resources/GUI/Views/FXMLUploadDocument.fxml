      <Button fx:id="buttonCancel" layoutX="415.0" layoutY="481.0" mnemonicParsing="false" onAction="#buttonCancel" text="Cancelar" />
      <Label layoutX="233.0" layoutY="212.0" text="Nombre del Documento:" />
      <Label layoutX="246.0" layoutY="283.0" text="URL del Documento:" />
      <Label fx:id="labelDocumentName" alignment="CENTER" layoutX="58.0" layoutY="246.0" prefHeight="18.0" prefWidth="483.0" />
