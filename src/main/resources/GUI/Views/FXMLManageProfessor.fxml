<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="565.0" prefWidth="600.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Controllers.FXMLManageProfessorController">
   <children>
      <Label fx:id="labelProfessorManage" alignment="CENTER" prefHeight="28.0" prefWidth="600.0" style="-fx-background-color: #146CD0; -fx-padding: 10;" text="Gestión de Profesor" textFill="WHITE">
         <font>
            <Font name="Times New Roman Bold" size="24.0" />
         </font>
      </Label>
      <Button fx:id="buttonInsertProfessor" layoutX="45.0" layoutY="91.0" mnemonicParsing="false" onAction="#buttonInsertProfessor" prefHeight="56.0" prefWidth="209.0" style="-fx-padding: 10; -fx-background-color: #22891F;" text="Registrar un nuevo profesor" textFill="WHITE" wrapText="true">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Button>
      <Label fx:id="labelModifyProfessor" alignment="CENTER" layoutY="215.0" prefHeight="30.0" prefWidth="600.0" style="-fx-background-color: #146CD0; -fx-padding: 5;" text="Modificar Profesor" textAlignment="CENTER" textFill="WHITE">
         <font>
            <Font name="Times New Roman Bold" size="18.0" />
         </font>
      </Label>
      <ComboBox fx:id="comboBoxProfessors" layoutX="44.0" layoutY="299.0" prefHeight="66.0" prefWidth="217.0" promptText="Seleccionar" style="-fx-padding: 20; -fx-background-color: #E8F0FE;" />
      <Button fx:id="buttonUpdate" layoutX="323.0" layoutY="312.0" mnemonicParsing="false" onAction="#clickOnButtonUpdate" prefHeight="26.0" prefWidth="210.0" style="-fx-padding: 5; -fx-background-color: orange;" text="Actualizar" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Button>
      <Button fx:id="buttonDeactive" layoutX="323.0" layoutY="345.0" mnemonicParsing="false" onAction="#clickOnButtonDeactivate" prefHeight="27.0" prefWidth="210.0" style="-fx-padding: 5; -fx-background-color: #EC407A;" text="Inactivar" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Button>
      <Button fx:id="buttonBack" layoutX="31.0" layoutY="509.0" mnemonicParsing="false" onAction="#buttonBack" prefHeight="27.0" prefWidth="100.0" style="-fx-background-color: red; -fx-padding: 5;" text="Regresar" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Button>
      <Button fx:id="buttonConsultProfessorsList" layoutX="339.0" layoutY="91.0" mnemonicParsing="false" prefHeight="56.0" prefWidth="209.0" style="-fx-padding: 10; -fx-background-color: #0097A7;" text="Consultar lista de profesores" textFill="WHITE" wrapText="true">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Label fx:id="labelSelectProfessor" layoutX="45.0" layoutY="275.0" text="Seleccione un profesor">
         <font>
            <Font name="Times New Roman Bold" size="14.0" />
         </font>
      </Label>
      <Label fx:id="labelProfessorStatus" layoutX="45.0" layoutY="372.0" text="Estado del profesor:">
         <font>
            <Font name="Times New Roman Bold" size="14.0" />
         </font>
      </Label>
      <Label fx:id="labelActiveInactive" layoutX="169.0" layoutY="372.0" text="Activo/Inactivo">
         <font>
            <Font name="Times New Roman" size="14.0" />
         </font>
      </Label>
      <Button fx:id="buttonView" layoutX="323.0" layoutY="279.0" mnemonicParsing="false" prefHeight="26.0" prefWidth="210.0" style="-fx-padding: 5; -fx-background-color: blue;" text="Ver" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
