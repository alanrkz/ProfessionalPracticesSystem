      <Button fx:id="buttonDeactive" layoutX="447.0" layoutY="446.0" mnemonicParsing="false" text="Inactivar" />
      <Button fx:id="buttonBack" layoutX="269.0" layoutY="515.0" mnemonicParsing="false" onAction="#buttonBack" text="Regresar" />
