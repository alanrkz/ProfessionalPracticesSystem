<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane id="AnchorPane" prefHeight="565.0" prefWidth="600.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="GUI.Controllers.FXMLManageProjectController">
   <children>
      <Label fx:id="labelTitleManageProject" layoutX="207.0" layoutY="35.0" text="Gestionar Proyecto">
         <font>
            <Font name="Times New Roman" size="24.0" />
         </font>
      </Label>
      <Button fx:id="buttonInsertProject" layoutX="212.0" layoutY="145.0" mnemonicParsing="false" onAction="#buttonInsertLinkedOrganization" prefHeight="26.0" prefWidth="174.0" text="Insertar Proyecto" />
      <Label fx:id="labelSelectProject" layoutX="213.0" layoutY="273.0" text="Seleccione un Proyecto:">
         <font>
            <Font name="Times New Roman" size="18.0" />
         </font>
      </Label>
      <ComboBox fx:id="comboBoxProjects" layoutX="225.0" layoutY="338.0" prefWidth="150.0" />
      <Button fx:id="buttonUpdate" layoutX="99.0" layoutY="440.0" mnemonicParsing="false" text="Actualizar" />
      <Button fx:id="buttonDeactive" layoutX="458.0" layoutY="440.0" mnemonicParsing="false" text="Inactivar" />
      <Button fx:id="buttonBack" layoutX="274.0" layoutY="500.0" mnemonicParsing="false" onAction="#buttonBack" text="Regresar" />
   </children>
</AnchorPane>
